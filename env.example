# 服务器端口
PORT=4000

# FFmpeg 允许访问的根目录（生产环境建议设置为项目目录）
FFMPEG_ROOT=/var/fluxio/app

# 文件上传大小限制（字节，MVP 默认 200MB）
MAX_FILE_SIZE=209715200

# 是否启用 CORS（如果需要跨域访问）
ENABLE_CORS=false

# 生产环境标识
NODE_ENV=production

# temp / logs 清理策略（可选）
TEMP_UPLOAD_TTL_HOURS=24
TEMP_SEQUENCE_TTL_HOURS=6
TEMP_PREVIEW_TTL_HOURS=24
LOG_RETENTION_DAYS=7
TEMP_MAX_SIZE_MB=5120
LOG_MAX_SIZE_MB=500
